      "link": null,
      "locked": false,
      "text": "\nDropbox is a cloud-based file storage service that allows users to store and share files.\nIt provides a secure and reliable way to store and access files from anywhere, on any device.\n\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nDropbox is a cloud-based file storage service that allows users to store and share files.\nIt provides a secure and reliable way to store and access files from anywhere, on any device.\n\n",
