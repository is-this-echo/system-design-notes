    {
      "id": "nZHrExgXaW2R_JWhptYw9",
      "type": "text",
      "x": 1361.7786335633493,
      "y": 962.7288703170576,
      "width": 372.9277038574219,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0d",
      "roundness": null,
      "seed": 1994503740,
      "version": 334,
      "versionNonce": 1068286268,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780141183122,
      "link": null,
      "locked": false,
      "text": "Put Nonce in cache the first time it comes in\nthe request and then if it's replayed it should\nbe in cache and we would know something's not \nright, as an additional measure of security\nwe also check the timestamp\n ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Put Nonce in cache the first time it comes in\nthe request and then if it's replayed it should\nbe in cache and we would know something's not \nright, as an additional measure of security\nwe also check the timestamp\n ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "tfry2Qv9ctGUTzZJGI_a0",
      "type": "text",
      "x": 2356.818046364963,
      "y": 1188.9687480567045,
      "width": 6.399993896484375,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
