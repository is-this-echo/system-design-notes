      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Audit\n- eventType\n- metadata\n- ...",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "F6pETMbCdEaPQV-nI9ZUf",
      "type": "text",
      "x": 3277.7135416327183,
      "y": 324.7774073271645,
      "width": 431.49303705337394,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "b0s",
      "roundness": null,
      "seed": 1630417028,
      "version": 824,
      "versionNonce": 1295437188,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780141183122,
      "link": null,
      "locked": false,
      "text": "To avoid overwriting the Transaction table\nwe can use an Audit table to write each and every\nrecord from WAL, immutable events.\n\nThis is ok but not the best way to audit.\n1) Each write requires writes to multiple tables\nwhich can be blocking and not scale for 10k qps.\n\n2) If a new service is introduced in the future,\nthen a new dev might miss writing to the Audit table.\nMeaning, you application code needs to know about it.\n\n3) This table is gonna grow the most so we need to \nshard this db in the future.\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To avoid overwriting the Transaction table\nwe can use an Audit table to write each and every\nrecord from WAL, immutable events.\n\nThis is ok but not the best way to audit.\n1) Each write requires writes to multiple tables\nwhich can be blocking and not scale for 10k qps.\n\n2) If a new service is introduced in the future,\nthen a new dev might miss writing to the Audit table.\nMeaning, you application code needs to know about it.\n\n3) This table is gonna grow the most so we need to \nshard this db in the future.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
