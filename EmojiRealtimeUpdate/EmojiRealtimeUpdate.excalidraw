    {
      "id": "10c9g078QkPTy7uEdMIcc",
      "type": "text",
      "x": 541.961960323273,
      "y": 91.5252741253565,
      "width": 670.8594970703125,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b23",
      "roundness": null,
      "seed": 1650455172,
      "version": 179,
      "versionNonce": 1692550076,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780676627159,
      "link": null,
      "locked": false,
      "text": "Design a system similar to Hotstar Sports Bar where users watching\na live cricket match can send emoji reactions and others see the\naggregated crowd sentiment in real-time.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design a system similar to Hotstar Sports Bar where users watching\na live cricket match can send emoji reactions and others see the\naggregated crowd sentiment in real-time.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D6-j4-gW4_MMY-Oh1FuIZ",
      "type": "text",
      "x": 548.8190857417998,
      "y": 260.0967026967851,
      "width": 540.01953125,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b24",
      "roundness": null,
      "seed": 656510268,
      "version": 168,
      "versionNonce": 216417412,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780677910159,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n\n- users can submit emojis during a live match\n- users can see aggregated counts of emojis in realtime",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n\n- users can submit emojis during a live match\n- users can see aggregated counts of emojis in realtime",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JaNHbVTW9jNeIJExQtmUC",
      "type": "text",
      "x": 548.8190094478545,
      "y": 409.6681541563973,
      "width": 486.8597412109375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b25",
      "roundness": null,
      "seed": 106224828,
      "version": 387,
      "versionNonce": 760165436,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780677929304,
      "link": null,
      "locked": false,
      "text": "Non-functional Requirements\n\n- Highly available system\n- Emoji aggregates should be low latency < 500ms\n- Scale to support 50M concurrent viewers\n- Durability of emoji submissions for analytics\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional Requirements\n\n- Highly available system\n- Emoji aggregates should be low latency < 500ms\n- Scale to support 50M concurrent viewers\n- Durability of emoji submissions for analytics\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
