      "link": null,
      "locked": false,
      "text": "Trigger document\ncompaction from db operation\nwhen all users are disconnected\nand store it in S3",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Trigger document\ncompaction from db operation when all users are disconnected and store it in S3",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "zTeSg6opRZJ6RYVtqJZoI",
      "type": "text",
      "x": 2005.353480241953,
      "y": 1417.0567288923908,
      "width": 88.89993286132812,
      "height": 25,
      "angle": 0,
