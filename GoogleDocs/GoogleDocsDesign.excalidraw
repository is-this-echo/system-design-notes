      "text": "Compaction service",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "aE2Fv_hs3LEYhMM7KFmAM",
      "originalText": "Compaction service",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D4QRFwClhmgcBjKrQoGPm",
      "type": "text",
      "x": 2438.613074638462,
      "y": 1431.0843549181545,
      "width": 438.17075406191935,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b08",
      "roundness": null,
      "seed": 1963194627,
      "version": 534,
      "versionNonce": 1980535341,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776441888518,
      "link": null,
      "locked": false,
      "text": "Used to collapse the operations in DB\nfor very old operations that might impact\nlatency for a recent user, we don't need to\ndo all transformations from past 1 week for\nany docId\n\nInitially, read from Document operations db\nand then when we have non-null snapshot,\ntake the snapshot from S3 and apply\noutstanding operations from Document\noperations db",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Used to collapse the operations in DB\nfor very old operations that might impact latency for a recent user, we don't need to do all transformations from past 1 week for any docId\n\nInitially, read from Document operations db and then when we have non-null snapshot, take the snapshot from S3 and apply outstanding operations from Document operations db",
      "autoResize": false,
      "lineHeight": 1.25
    },
