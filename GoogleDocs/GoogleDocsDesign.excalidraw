    {
      "id": "iHJTZe8A_s0Re0qRqADl0",
      "type": "text",
      "x": 1055.7649841308587,
      "y": 806.5049018254356,
      "width": 134.94061279296875,
      "height": 46.905865720685675,
      "angle": 0,
      "strokeColor": "#1e1e1e",
