    {
      "id": "qzIwq98ua5H7yoSNY_IdU",
      "type": "text",
      "x": 2170.2516680553967,
      "y": 462.87621128815846,
      "width": 353.5283552490527,
      "height": 75.00000000000001,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ay",
      "roundness": null,
      "seed": 1416446947,
      "version": 558,
      "versionNonce": 265041123,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776442782447,
      "link": null,
      "locked": false,
      "text": "When the Document service fails, all\nusers are disconnected and the\ncursor map is invalid as well",
      "fontSize": 20.000000000000004,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When the Document service fails, all users are disconnected and the cursor map is invalid as well",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "KMQf4BbcUti6lWWyf0U21",
      "type": "text",
      "x": 2172.483556951436,
      "y": 567.1264865495261,
      "width": 397.4197082519531,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "az",
      "roundness": null,
      "seed": 1992432291,
      "version": 491,
      "versionNonce": 1457102979,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776442782447,
      "link": null,
      "locked": false,
      "text": "We need to scale the Document service \nbecause a single service can't handle all\nthe websocket connections, memory map\nof Cursors and CPU intensive operations",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We need to scale the Document service \nbecause a single service can't handle all\nthe websocket connections, memory map\nof Cursors and CPU intensive operations",
      "autoResize": true,
      "lineHeight": 1.25
    },
