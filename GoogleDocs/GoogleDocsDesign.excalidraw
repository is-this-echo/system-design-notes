    {
      "id": "VPsyb673BI40rgo-vRi3A",
      "type": "text",
      "x": 312.5302022503769,
      "y": 2438.952715205211,
      "width": 660.199462890625,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0M",
      "roundness": null,
      "seed": 1410189165,
      "version": 38,
      "versionNonce": 125936899,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1776442758696,
      "link": null,
      "locked": false,
      "text": "OT must also run on the client side.\n Users see their own edits immediately (optimistic local application),\n but another user's edit might land on the server before theirs.\nThe client needs to transform incoming remote operations against \nits pending local operations to maintain consistency.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "OT must also run on the client side.\n Users see their own edits immediately (optimistic local application),\n but another user's edit might land on the server before theirs.\nThe client needs to transform incoming remote operations against \nits pending local operations to maintain consistency.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "skQo1jcxszIPzChuWBJnj",
      "type": "text",
      "x": 913.3488247152405,
      "y": 551.1355044278454,
      "width": 513.3721292008611,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0N",
      "roundness": null,
      "seed": 1198030915,
      "version": 158,
      "versionNonce": 1345199757,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776442807830,
      "link": null,
      "locked": false,
      "text": "OT must also run on the client side.\n Users see their own edits immediately (optimistic\nlocal application), but another user's edit might land\non the server before theirs. The client needs to\ntransform incoming remote operations against its\npending local operations to maintain consistency.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "OT must also run on the client side.\n Users see their own edits immediately (optimistic local application), but another user's edit might land on the server before theirs. The client needs to transform incoming remote operations against its pending local operations to maintain consistency.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "N66HpBpw8Y2pRNuUsYbj0",
      "type": "text",
      "x": 2627.5419547760466,
      "y": 704.8238301990372,
      "width": 715.8395385742188,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0O",
      "roundness": null,
      "seed": 1960354627,
      "version": 107,
      "versionNonce": 897432845,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776442906733,
      "link": null,
      "locked": false,
      "text": "The client initially connects to any server via round-robin.\nThat server checks the consistent hash ring for the document ID \nand, if it's not the responsible server,  responds with a redirect\nto the correct one. The client then connects directly to the right server\nand upgrades to a websocket.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The client initially connects to any server via round-robin.\nThat server checks the consistent hash ring for the document ID \nand, if it's not the responsible server,  responds with a redirect\nto the correct one. The client then connects directly to the right server\nand upgrades to a websocket.",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ],
