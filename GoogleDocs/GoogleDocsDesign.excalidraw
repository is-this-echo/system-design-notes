    {
      "id": "yPFU1EsnfEbifvHDZGz3d",
      "type": "text",
      "x": 1585.989310762082,
      "y": 1430.8237596276863,
      "width": 212.4834142548297,
      "height": 46.905865720685675,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
