    {
      "id": "P90M8aw4PGd0z7YuxDwB-",
      "type": "text",
      "x": 2947.749594566271,
      "y": 1445.1117863590118,
      "width": 487.5396423339844,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 2110558349,
      "version": 432,
      "versionNonce": 1928789859,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776441887028,
      "link": null,
      "locked": false,
      "text": "Another benefit to this Compaction service\nis that when snapshot is complete, we write\nthe snapshotId in Metadata db after\nstoring in S3,  purge all the entries of\nDocument ops db. New users will read from\nS3 summary and then apply subsequent operations\nfrom Document ops db",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Another benefit to this Compaction service\nis that when snapshot is complete, we write\nthe snapshotId in Metadata db after\nstoring in S3,  purge all the entries of\nDocument ops db. New users will read from\nS3 summary and then apply subsequent operations\nfrom Document ops db",
      "autoResize": true,
      "lineHeight": 1.25
    },
