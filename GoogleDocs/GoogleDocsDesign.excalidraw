    },
    {
      "id": "-12xhZF44cswjZMvFYaMZ",
      "type": "text",
      "x": 1527.4992272834215,
      "y": 215.2759961815063,
      "width": 543.9195556640625,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "as",
      "roundness": null,
      "seed": 1377262829,
      "version": 1259,
      "versionNonce": 543785517,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776442778493,
      "link": null,
      "locked": false,
      "text": "Cursor data is required only when user is\n connected through ws to our webserver.\n\nWhen an user is online they submit their cursor\nlocation using \"update\" event api and then\nthe Doc service records the details in the map\nfor a particular docId, all the connected users\n get this position via \"receive\" update fan-out.\n\nWhen a new user joins, we send the updates for \nall online users for that docId from the map, and\nthen it receives update events for subsequent changes.\n\nWhen an user disconnects from the doc, ws conn\nis closed, we remove it's entry from the map and\nthen notify all other users via an \"update\" event.\n\nSo, no need to store stuff in db as long as\nall users are connected to same server for the\nsame docId.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cursor data is required only when user is\n connected through ws to our webserver.\n\nWhen an user is online they submit their cursor\nlocation using \"update\" event api and then\nthe Doc service records the details in the map\nfor a particular docId, all the connected users\n get this position via \"receive\" update fan-out.\n\nWhen a new user joins, we send the updates for \nall online users for that docId from the map, and\nthen it receives update events for subsequent changes.\n\nWhen an user disconnects from the doc, ws conn\nis closed, we remove it's entry from the map and\nthen notify all other users via an \"update\" event.\n\nSo, no need to store stuff in db as long as\nall users are connected to same server for the\nsame docId.",
      "autoResize": true,
      "lineHeight": 1.25
    },
