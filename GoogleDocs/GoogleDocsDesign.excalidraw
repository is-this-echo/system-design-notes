    },
    {
      "id": "87sCx7yovEM--93gcBAG9",
      "type": "text",
      "x": 997.9204494167525,
      "y": 1615.673983570105,
      "width": 8,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
