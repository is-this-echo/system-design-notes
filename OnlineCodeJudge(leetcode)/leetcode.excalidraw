    },
    {
      "id": "KWCv_57dDBN0WVzTeguWU",
      "type": "text",
      "x": 2325.8842772226485,
      "y": 759.2003046974305,
      "width": 93.63189697265625,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
