    {
      "id": "YCfGhvnBWkOPwEBiyTwF8",
      "type": "text",
      "x": 1559.346360100639,
      "y": 360.4509807465578,
      "width": 183.23182678222656,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 20,
      "groupIds": [],
      "frameId": null,
      "index": "b21",
      "roundness": null,
      "seed": 607846544,
      "version": 114,
      "versionNonce": 1503616112,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769327694891,
      "link": null,
      "locked": false,
      "text": "Cron job refreshes the \ncache every 5s by \nrunning expensive query\n(additional dependency)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cron job refreshes the \ncache every 5s by \nrunning expensive query\n(additional dependency)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wBuixGYFYJKvoA4aD636Q",
      "type": "text",
      "x": 2204.178968089907,
      "y": -120.72325102313191,
      "width": 492.63958740234375,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b22",
      "roundness": null,
      "seed": 432171664,
      "version": 886,
      "versionNonce": 1074271888,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769331418698,
      "link": null,
      "locked": false,
      "text": "We can cache the leaderboard query result\nusing Redis but to refresh it, stale the cache\nby using TTL on the records.\nThe problem here is that there will be at least one \nunlucky person who will miss cache and hit DB.\nWe can use a cron job to solve this issue as shown.\nIf we use this then it means, no user will hit the DB.\n\nStill, its pretty stale, even we run cron job every 5 sec.\nIf the DB query takes more than 3sec and cron job runs after\nevery 3s then there will be overlapping jobs and it will become\ncomplex to manage.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We can cache the leaderboard query result\nusing Redis but to refresh it, stale the cache\nby using TTL on the records.\nThe problem here is that there will be at least one \nunlucky person who will miss cache and hit DB.\nWe can use a cron job to solve this issue as shown.\nIf we use this then it means, no user will hit the DB.\n\nStill, its pretty stale, even we run cron job every 5 sec.\nIf the DB query takes more than 3sec and cron job runs after\nevery 3s then there will be overlapping jobs and it will become\ncomplex to manage.",
      "autoResize": true,
      "lineHeight": 1.25
    },
