    },
    {
      "id": "21rLuwPUZhExssGD9RCyZ",
      "type": "text",
      "x": 2476.2559660730863,
      "y": 890.3967498888907,
      "width": 402.5115966796875,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1m",
      "roundness": null,
      "seed": 26227824,
      "version": 620,
      "versionNonce": 239410320,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769332538884,
      "link": null,
      "locked": false,
      "text": "SELECT userId,\n            COUNT(*) AS passedSubmissions,\n            MAX(submittedAt) AS lastSubmissionTime\nFROM \n    Submission\nWHERE \n    competitionId = {compId} AND passed = TRUE\nGROUP BY\n    userId\nORDER BY\n    passedSubmissions DESC,\n    lastSubmissionTime ASC;\n\nQuery the Submission table grouping by userId to\nfetch the leaderboard results",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT userId,\n            COUNT(*) AS passedSubmissions,\n            MAX(submittedAt) AS lastSubmissionTime\nFROM \n    Submission\nWHERE \n    competitionId = {compId} AND passed = TRUE\nGROUP BY\n    userId\nORDER BY\n    passedSubmissions DESC,\n    lastSubmissionTime ASC;\n\nQuery the Submission table grouping by userId to\nfetch the leaderboard results",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rKns4mjM08qVdwqRAvvUp",
      "type": "text",
      "x": 2007.89054807131,
      "y": 1135.3035496742823,
      "width": 311.66375732421875,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1n",
      "roundness": null,
      "seed": 1067825264,
      "version": 485,
      "versionNonce": 1892424816,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769332596856,
      "link": null,
      "locked": false,
      "text": "Security\n- Explicit timeout per execution\n(to handle infinite loops or such)\n\n- CPU and memory limits\n(if exceeded the container is destroyed\nand return some error to user)\n\n- Read-only file system\n(write to /tmp)\n\n- Network isolation (VPC)\n- No system calls\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Security\n- Explicit timeout per execution\n(to handle infinite loops or such)\n\n- CPU and memory limits\n(if exceeded the container is destroyed\nand return some error to user)\n\n- Read-only file system\n(write to /tmp)\n\n- Network isolation (VPC)\n- No system calls\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
