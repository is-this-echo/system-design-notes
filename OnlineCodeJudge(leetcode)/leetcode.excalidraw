    },
    {
      "id": "o9rUWfW0pebxTpr9zou21",
      "type": "text",
      "x": 2846.1461471073208,
      "y": 666.3433453090609,
      "width": 508.04754638671875,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1h",
      "roundness": null,
      "seed": 969718384,
      "version": 756,
      "versionNonce": 1780127856,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769281229814,
      "link": null,
      "locked": false,
      "text": "What is a competition?\n- 90 mins\n- 4 problems\n- up to 100k users\n- rank by number of problems solved correctly in the 90mins.\nIn case of a tie, rank by fastest time to complete, in case that\ntime is also same, consider the runtime of the code to pass test\ncases and then the number of mistakes before code is accepted.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is a competition?\n- 90 mins\n- 4 problems\n- up to 100k users\n- rank by number of problems solved correctly in the 90mins.\nIn case of a tie, rank by fastest time to complete, in case that\ntime is also same, consider the runtime of the code to pass test\ncases and then the number of mistakes before code is accepted.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JyVDeOWRbzC_oB79wwhlV",
      "type": "text",
      "x": 2488.5842589121016,
      "y": 757.0002009376649,
      "width": 35.551971435546875,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
