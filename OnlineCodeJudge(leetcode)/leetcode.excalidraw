    {
      "id": "PHzcLzLiKHtikZXvHDGbk",
      "type": "text",
      "x": 2745.2876661952173,
      "y": -70.08502487381492,
      "width": 451.8875427246094,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2K",
      "roundness": null,
      "seed": 124536976,
      "version": 518,
      "versionNonce": 1132406896,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769331422339,
      "link": null,
      "locked": false,
      "text": "One option is to run a cheaper query for \na single user and update that value in Redis\nfor the leaderboard,\nmeans every user needs to fetch all data from Redis\nin O(1) time and then modify the user submission and time\nand save it in Redis again, processing a lot of data\neach time in memory. Not the best solution.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One option is to run a cheaper query for \na single user and update that value in Redis\nfor the leaderboard,\nmeans every user needs to fetch all data from Redis\nin O(1) time and then modify the user submission and time\nand save it in Redis again, processing a lot of data\neach time in memory. Not the best solution.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "keLcjJIwQ7eV6p_ySiL5u",
      "type": "text",
      "x": 1945.3089553794498,
      "y": 210.15489937129132,
      "width": 242.2397918701172,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2L",
      "roundness": null,
      "seed": 1188270192,
      "version": 112,
      "versionNonce": 773953680,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769331430235,
      "link": null,
      "locked": false,
      "text": "key : leaderboardCompetitionId\nvalue : SortedSet",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "key : leaderboardCompetitionId\nvalue : SortedSet",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gdSx-mhYfBncibRxnFAXZ",
      "type": "text",
      "x": 2361.2376116180603,
      "y": 214.43919188401583,
      "width": 325.23175048828125,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2M",
      "roundness": null,
      "seed": 425899120,
      "version": 227,
      "versionNonce": 878952080,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769331435323,
      "link": null,
      "locked": false,
      "text": "SortedSet allows range queries\nin O(logn) time.\nIf page = 2, size = 100 in url call\nthen we can fetch elements from 101-200",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SortedSet allows range queries\nin O(logn) time.\nIf page = 2, size = 100 in url call\nthen we can fetch elements from 101-200",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vZ5ysXHRgQc1cCZ2DOhcu",
      "type": "text",
      "x": 2079.837180030695,
      "y": 280.86409927372466,
      "width": 280.09810023961836,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2N",
      "roundness": null,
      "seed": 38663280,
      "version": 238,
      "versionNonce": 1166800496,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769331432063,
      "link": null,
      "locked": false,
      "text": "data structure used for value:\nelement: userId\nranking on : score\n(score maybe decimal considering\ntime taken incase of tie)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "data structure used for value:\nelement: userId\nranking on : score\n(score maybe decimal considering time taken incase of tie)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "uRjale0psu8WQF0s6fU_8",
      "type": "text",
      "x": 2355.0900360623305,
      "y": 321.77528954907405,
      "width": 352.97326104016605,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2O",
      "roundness": null,
      "seed": 1422966928,
      "version": 508,
      "versionNonce": 1575434384,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769331441403,
      "link": null,
      "locked": false,
      "text": "Whenever an user submits a solution\nfor a competition we pick that user\nfrom Redis, update their scrore if they pass\nand then put it back in Redis.\nWe then serve live-leaderboard queries\nfrom Redis itself without expensive\nDB calls.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Whenever an user submits a solution\nfor a competition we pick that user\nfrom Redis, update their scrore if they pass\nand then put it back in Redis.\nWe then serve live-leaderboard queries\nfrom Redis itself without expensive\nDB calls.",
      "autoResize": false,
      "lineHeight": 1.25
    },
