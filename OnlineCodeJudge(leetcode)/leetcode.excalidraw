      "isDeleted": false,
      "boundElements": null,
      "updated": 1769278203490,
      "link": null,
      "locked": false,
      "text": "Submission\n- id (PK)\n- userId (FK)\n- problemId (FK)\n- competitionId? (FK)\n- testCaseResults\n- passed\n- error?\n- runTimeOfTestCases\n- completionTime\n- ...",
