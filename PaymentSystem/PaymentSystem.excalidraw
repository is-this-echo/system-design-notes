      "updated": 1780128759122,
      "link": null,
      "locked": false,
      "text": "\"API\" call to get\ncurrent status\n- get batch rec. file",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "88qJ5sCAKrqoHv47P7RfJ",
      "originalText": "\"API\" call to get\ncurrent status\n- get batch rec. file",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WMqgl30Fl-9Qy1EIX7jBs",
      "type": "text",
      "x": 3024.845588408679,
      "y": 976.152666454243,
      "width": 608.3834838867188,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1F",
      "roundness": null,
      "seed": 140756668,
      "version": 535,
      "versionNonce": 1705499836,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780129025031,
      "link": null,
      "locked": false,
      "text": "Setup different topics to retry api calls to get pending status.\nInitially, use a topic for immediate timeout, then api call from here\ngets timed out, put it in a different topic and repeat using exponential\nbackoff.\n\nPayment Networks also provides something like batch reconciliation file\nfor hourly or daily intervals for transactionIDs you specify. We can \nmake use of that to reconcile with our DB and update payment status there.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Setup different topics to retry api calls to get pending status.\nInitially, use a topic for immediate timeout, then api call from here\ngets timed out, put it in a different topic and repeat using exponential\nbackoff.\n\nPayment Networks also provides something like batch reconciliation file\nfor hourly or daily intervals for transactionIDs you specify. We can \nmake use of that to reconcile with our DB and update payment status there.",
      "autoResize": true,
      "lineHeight": 1.25
    },
