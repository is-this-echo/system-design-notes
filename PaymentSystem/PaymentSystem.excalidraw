      "isDeleted": true,
      "boundElements": null,
      "updated": 1780085770248,
      "link": null,
      "locked": false,
      "text": "// Example request with signature",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// Example request with signature",
