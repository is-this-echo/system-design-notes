  "elements": [
    {
      "id": "af6ZlmqdLLkLNQQJcNftH",
      "type": "text",
      "x": 329.8000183105469,
      "y": 51.39996337890625,
      "width": 317.8246330618857,
      "height": 60.39999389648438,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a0",
      "roundness": null,
      "seed": 18023471,
      "version": 223,
      "versionNonce": 206540897,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776781618772,
      "link": null,
      "locked": false,
      "text": "Payment System like Stripe\n ",
      "fontSize": 24.159997558593737,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Payment System like Stripe\n ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "OWI3z1MiuQlvMwKRgn3IM",
      "type": "text",
      "x": 324.0000305175781,
      "y": 89.70002746582031,
      "width": 816.52734375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 343630447,
      "version": 481,
      "versionNonce": 852266671,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776781891752,
      "link": null,
      "locked": false,
      "text": "Payment processing systems like Stripe allow business (referred to throughout as merchants)\nto accept payment from customers, without having to build their own payment processing infrastructure.\nCustomer input their payment details on the merchant's website, and the merchant sends the\npayment details to Stripe. Stripe then processes the payment and returns the result\nto the merchant.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Payment processing systems like Stripe allow business (referred to throughout as merchants)\nto accept payment from customers, without having to build their own payment processing infrastructure.\nCustomer input their payment details on the merchant's website, and the merchant sends the\npayment details to Stripe. Stripe then processes the payment and returns the result\nto the merchant.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hXIAsdYRk9n2rJUoeoflC",
      "type": "text",
      "x": 326.4000244140625,
      "y": 271,
      "width": 624.41552734375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 575650191,
      "version": 276,
      "versionNonce": 2019104225,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776783894804,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n\n- Merchant should be able to create PaymentIntent (Merchant = HelloInterview)\n- Users should be able to pay via credit/debit card\n- Merchants should be able to view status updates for payment",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n\n- Merchant should be able to create PaymentIntent (Merchant = HelloInterview)\n- Users should be able to pay via credit/debit card\n- Merchants should be able to view status updates for payment",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "P_-pxEnq5_70qTr9LcOih",
      "type": "text",
      "x": 322,
      "y": 431,
      "width": 71.48793029785156,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a4",
      "roundness": null,
      "seed": 1851154319,
      "version": 27,
      "versionNonce": 1530846401,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776784022515,
      "link": null,
      "locked": false,
      "text": "Scale\n- 10k tps",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scale\n- 10k tps",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nj94Gnfi8A4c837-30ZZz",
      "type": "text",
      "x": 322.79998779296875,
      "y": 521,
      "width": 565.4075927734375,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 1451784033,
      "version": 382,
      "versionNonce": 787869700,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779984868177,
      "link": null,
      "locked": false,
      "text": "Non-functional Requirements\n\n- System should be highly secure (encryption stuff)\n- Transaction safety and financial integrity despite the\n   async eventually consistent nature of the system (no double charges)\n- Strong durability (auditability)\n- Scale to 10k tps\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional Requirements\n\n- System should be highly secure (encryption stuff)\n- Transaction safety and financial integrity despite the\n   async eventually consistent nature of the system (no double charges)\n- Strong durability (auditability)\n- Scale to 10k tps\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "j-t39p9waJgibjXLHn0m-",
      "type": "text",
      "x": 321.6000061035156,
      "y": 729.3999633789062,
      "width": 415.7756652832031,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a8",
      "roundness": null,
      "seed": 822410799,
      "version": 171,
      "versionNonce": 2036680879,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776784984614,
      "link": null,
      "locked": false,
      "text": "Core Entities\n\n- Merchant\n- PaymentIntent (tracks full lifecycle of transaction)\n- Transaction (links back to single PaymentIntent)\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core Entities\n\n- Merchant\n- PaymentIntent (tracks full lifecycle of transaction)\n- Transaction (links back to single PaymentIntent)\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "FWMnvRzltTATXnZcPkYUi",
      "type": "text",
      "x": 330.3999938964844,
      "y": 900.8000183105469,
      "width": 350.62371826171875,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a9",
      "roundness": null,
      "seed": 243139457,
      "version": 208,
      "versionNonce": 1548657825,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776785214712,
      "link": null,
      "locked": false,
      "text": "API\n\n// Create a PaymentIntent\nPOST /payment-intents -> PaymentIntentId\n{\n     amount,\n     ccy,\n     description\n}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\n// Create a PaymentIntent\nPOST /payment-intents -> PaymentIntentId\n{\n     amount,\n     ccy,\n     description\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JpRTQg9pouOEX1yPPgjbI",
      "type": "text",
      "x": 338.4000549316406,
      "y": 1109.199951171875,
      "width": 440.5436706542969,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aA",
      "roundness": null,
      "seed": 802295663,
      "version": 155,
      "versionNonce": 199527169,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776785255007,
      "link": null,
      "locked": false,
      "text": "// Make Payment\nPOST /payment-intents/:paymentIntentId/transactions\n{\n     type,  // charge\n     cardDetails\n}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// Make Payment\nPOST /payment-intents/:paymentIntentId/transactions\n{\n     type,  // charge\n     cardDetails\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
