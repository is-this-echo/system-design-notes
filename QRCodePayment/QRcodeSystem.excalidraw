    {
      "id": "8K78TgDSCNhKgFRpeGFur",
      "type": "text",
      "x": 2093.9689135914537,
      "y": 1399.317878210093,
      "width": 351.23968505859375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
