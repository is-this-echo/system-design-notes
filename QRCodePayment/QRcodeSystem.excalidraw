      "link": null,
      "locked": false,
      "text": "\nCore Entities\n\n- Merchant\n- Customer\n- QRCode\n- Payment\n- TransactionLedger",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nCore Entities\n\n- Merchant\n- Customer\n- QRCode\n- Payment\n- TransactionLedger",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "tTe8yZG6RNuesXQWTe6r4",
      "type": "text",
      "x": 340.47950187189343,
      "y": 1136.509002485816,
      "width": 525.9595947265625,
      "height": 1025,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2q",
      "roundness": null,
      "seed": 139473668,
      "version": 980,
      "versionNonce": 1514753284,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781109864273,
      "link": null,
      "locked": false,
      "text": "API\n\nBuyer\n-------\nGET /qr/:qrId -> {merchantName, amount...}\n\nPOST /payments\n{\n    \"qrId\" : \"m123\",\n    \"buyerId\" : \"b123\",\n    \"amount\" : 100\n    \"ccy\" : JPY\n}\n\nGET /payments/:paymentId -> Payment\nGET / payments -> Payment[]\n\n\nSeller\n-------\nPOST /qr -> QR(id, imageUrl)\n{\n     \"merchantId\": \"1234\",\n     \"amount\" : 500 \n}\n\nGET /merchants/:merchantId/payments -> Payment[]\n\nPATCH /payments/:paymentId/refund -> Payment\n\ninternal api\n--------------\nPOST /ledger/transfer\n{\n    \"fromAccount\" : \"buyer123\",\n    \"toAccount\" : \"merchant235\",\n    \"amount\" : 4000,\n    \"ccy\" : JPY,\n    paymentId : \"p242\",\n    idempotencyKey : \"payment23532\"\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\nBuyer\n-------\nGET /qr/:qrId -> {merchantName, amount...}\n\nPOST /payments\n{\n    \"qrId\" : \"m123\",\n    \"buyerId\" : \"b123\",\n    \"amount\" : 100\n    \"ccy\" : JPY\n}\n\nGET /payments/:paymentId -> Payment\nGET / payments -> Payment[]\n\n\nSeller\n-------\nPOST /qr -> QR(id, imageUrl)\n{\n     \"merchantId\": \"1234\",\n     \"amount\" : 500 \n}\n\nGET /merchants/:merchantId/payments -> Payment[]\n\nPATCH /payments/:paymentId/refund -> Payment\n\ninternal api\n--------------\nPOST /ledger/transfer\n{\n    \"fromAccount\" : \"buyer123\",\n    \"toAccount\" : \"merchant235\",\n    \"amount\" : 4000,\n    \"ccy\" : JPY,\n    paymentId : \"p242\",\n    idempotencyKey : \"payment23532\"\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
