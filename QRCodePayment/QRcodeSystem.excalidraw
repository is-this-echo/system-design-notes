      "isDeleted": true,
      "boundElements": null,
      "updated": 1781111019185,
      "link": null,
      "locked": false,
      "text": "SAGA pattern\n\n1. Create Payment(PENDING)\n2. Call Ledger Service\n3. Ledger succeeds\n4. Update Payment(SUCCESS)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SAGA pattern\n\n1. Create Payment(PENDING)\n2. Call Ledger Service\n3. Ledger succeeds\n4. Update Payment(SUCCESS)",
      "autoResize": true,
      "lineHeight": 1.25
    },
