    },
    {
      "id": "4ZXBwN5Er-qXYpmQ4ZuuH",
      "type": "text",
      "x": 2974.7801106758166,
      "y": 1267.7580592759232,
      "width": 393.2197265625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b47",
      "roundness": null,
      "seed": 1908008068,
      "version": 153,
      "versionNonce": 1632195772,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781112520145,
      "link": null,
      "locked": false,
      "text": "Ledger service finds\nthe accountId using buyer and merchant\nids it receives from Payment service",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ledger service finds\nthe accountId using buyer and merchant\nids it receives from Payment service",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "haxv6TSuIMxznqd3j45zu",
      "type": "text",
      "x": 3429.461025042052,
      "y": 1246.357257346343,
      "width": 366.79974365234375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b48",
      "roundness": null,
      "seed": 1345860100,
      "version": 178,
      "versionNonce": 1145298180,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781112521265,
      "link": null,
      "locked": false,
      "text": "To avoid idempotencyKey\nand timestamp duplication\nuse a separate Journal table\n1 Journal entry -> many ledger entries",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To avoid idempotencyKey\nand timestamp duplication\nuse a separate Journal table\n1 Journal entry -> many ledger entries",
      "autoResize": true,
      "lineHeight": 1.25
    },
