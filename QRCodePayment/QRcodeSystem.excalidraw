    {
      "id": "SPDi8Z966aUHaa4pkUyhs",
      "type": "text",
      "x": 1621.5874431549555,
      "y": 1065.0856400747148,
      "width": 741.5595703125,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
