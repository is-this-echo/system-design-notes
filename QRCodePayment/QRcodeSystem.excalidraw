      "link": null,
      "locked": false,
      "text": "Kafka handles sudden burst of requests.\nIt also de-couples all the different services.\nReplay due to message persistence.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kafka handles sudden burst of requests.\nIt also de-couples all the different services.\nReplay due to message persistence.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
