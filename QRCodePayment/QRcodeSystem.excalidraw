    {
      "id": "10c9g078QkPTy7uEdMIcc",
      "type": "text",
      "x": 541.961960323273,
      "y": 91.5252741253565,
      "width": 670.8594970703125,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
