      "versionNonce": 86267908,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780743523247,
      "link": null,
      "locked": false,
      "text": "Capacity Estimation\n\n50 M viewers\n20% active users = 10 M\nEach viewer sends 1 emoji / 5 sec\nWrite qps = 10 / 5 = 2M writes / sec\nPeak load = 4 M writes / sec = 4M qps",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Capacity Estimation\n\n50 M viewers\n20% active users = 10 M\nEach viewer sends 1 emoji / 5 sec\nWrite qps = 10 / 5 = 2M writes / sec\nPeak load = 4 M writes / sec = 4M qps",
      "autoResize": true,
      "lineHeight": 1.25
    },
