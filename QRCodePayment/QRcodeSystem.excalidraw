    {
      "id": "YbTQGy5-0poq-roChd8Bz",
      "type": "text",
      "x": 3314.6395706598546,
      "y": 850.0575875719355,
      "width": 795.0594482421875,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4X",
      "roundness": null,
      "seed": 1818783748,
      "version": 26,
      "versionNonce": 970942140,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781113384532,
      "link": null,
      "locked": false,
      "text": "Initially I'd shard by AccountId using hash-based partitioning. As the number of\nshards grows, I'd use consistent hashing with virtual nodes to minimize data\nmovement during resharding. However, I'd also watch for hot accounts because all\ntransactions for a single account would still route to the same shard, creating\npotential write contention.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Initially I'd shard by AccountId using hash-based partitioning. As the number of shards grows, I'd use consistent hashing with virtual nodes to minimize data movement during resharding. However, I'd also watch for hot accounts because all transactions for a single account would still route to the same shard, creating potential write contention.",
      "autoResize": false,
      "lineHeight": 1.25
    }
  ],
