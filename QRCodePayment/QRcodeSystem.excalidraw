    {
      "id": "4g8tlmlMcHXsR95wGqmvh",
      "type": "text",
      "x": 333.3778008355036,
      "y": 224.36666361490884,
      "width": 724.5394897460938,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
