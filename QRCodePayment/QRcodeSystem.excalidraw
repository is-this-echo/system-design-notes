      "isDeleted": false,
      "boundElements": null,
      "updated": 1781111117974,
      "link": null,
      "locked": false,
      "text": "Distributed transactions\nacross Payment and Ledger services",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Distributed transactions\nacross Payment and Ledger services",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9OHIVOZ0q7pf6Cocgbik-",
      "type": "text",
      "x": 2020.0189386962932,
      "y": 1571.1264704872506,
      "width": 342.77978515625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b44",
      "roundness": null,
      "seed": 1284639548,
      "version": 92,
      "versionNonce": 356616324,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781111169994,
      "link": null,
      "locked": false,
      "text": "If Ledger service fails\nupdate payment status to FAILED",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If Ledger service fails\nupdate payment status to FAILED",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Cq58M8k_HaniEhixKPCUe",
      "type": "text",
      "x": 1826.3882040529154,
      "y": 175.99115964668783,
      "width": 864.139404296875,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b45",
      "roundness": null,
      "seed": 217241988,
      "version": 75,
      "versionNonce": 1326686340,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781111249398,
      "link": null,
      "locked": false,
      "text": "QR Service owns a QR database. Payment Service owns a payment database.\nLedger Service owns a dedicated SQL ledger database. \nWithin Ledger Service, accounts and ledger entries live in the same database \nand are updated in a single ACID transaction.\nAcross Payment DB and Ledger DB, I would avoid distributed transactions and \ninstead use a Saga pattern where Payment Service records a pending payment, \ninvokes Ledger Service, and then updates the payment state based on the ledger result.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "QR Service owns a QR database. Payment Service owns a payment database.\nLedger Service owns a dedicated SQL ledger database. \nWithin Ledger Service, accounts and ledger entries live in the same database \nand are updated in a single ACID transaction.\nAcross Payment DB and Ledger DB, I would avoid distributed transactions and \ninstead use a Saga pattern where Payment Service records a pending payment, \ninvokes Ledger Service, and then updates the payment state based on the ledger result.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JWxG7B3wrBCuL-rmUytFV",
      "type": "text",
      "x": 3199.132043653416,
      "y": 1210.4884083252243,
      "width": 8,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b46",
      "roundness": null,
      "seed": 1172673852,
      "version": 3,
      "versionNonce": 1077943172,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1781112218467,
      "link": null,
      "locked": false,
      "text": "",
      "fontSize": 20,
