      "updated": 1781112225195,
      "link": null,
      "locked": false,
      "text": "Accounts and transaction ledger tables should\nbe in same db for ease of atomic transactions",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Accounts and transaction ledger tables should\nbe in same db for ease of atomic transactions",
      "autoResize": true,
      "lineHeight": 1.25
    },
