      "boundElements": [],
      "updated": 1780743523247,
      "link": null,
      "locked": false,
      "text": "API\n\nPOST /matches/{matchId}/emoji -> accepted\n{\n    \"emoji\" : \"👌\"\n}\n\nGET /matches/{matchId}/sentiment -> { \"smile\" : 200000, \"heart\" : 50000}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\nPOST /matches/{matchId}/emoji -> accepted\n{\n    \"emoji\" : \"👌\"\n}\n\nGET /matches/{matchId}/sentiment -> { \"smile\" : 200000, \"heart\" : 50000}",
      "autoResize": true,
      "lineHeight": 1.25
    },
