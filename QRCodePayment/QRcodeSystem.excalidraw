    {
      "id": "EhttclCuQIP6f_aTaQx_C",
      "type": "text",
      "x": 3033.60132510571,
      "y": 763.6592424553694,
      "width": 384.6876220703125,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b11",
      "roundness": null,
      "seed": 2020027780,
      "version": 568,
      "versionNonce": 1981251260,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780141183122,
      "link": null,
      "locked": false,
      "text": "Isn't CDC a single point of failure?\n- Yes, to handle that we can replicate the infra,\nmultiple Kafka streams with different CDC.\n- Fallback to the application level code writing to\nthe Audit table. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Isn't CDC a single point of failure?\n- Yes, to handle that we can replicate the infra,\nmultiple Kafka streams with different CDC.\n- Fallback to the application level code writing to\nthe Audit table. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TLqrvlsEBeMu-gu7H8xfO",
      "type": "text",
      "x": 2252.314497485832,
      "y": 80.37534616368936,
      "width": 6.399993896484375,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b12",
      "roundness": null,
      "seed": 1837148036,
      "version": 3,
      "versionNonce": 1775736452,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780126590565,
