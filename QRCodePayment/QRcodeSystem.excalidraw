    {
      "id": "cWCj_qLDBEcLTgauclbzn",
      "type": "text",
      "x": 550.9262264191157,
      "y": 640.0966836232988,
      "width": 377.759765625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
