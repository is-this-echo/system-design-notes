      "link": null,
      "locked": false,
      "text": "Use Dynamo DB (no-SQL) overall instead of\nSQL DB, easy scaled by AWS.\n- no need of extra Redis  instance for\nlocks\n- can do TTL on rows and columns\n\nDriverLock table (TTL)\n- Driver Id",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Use Dynamo DB (no-SQL) overall instead of SQL DB, easy scaled by AWS.\n- no need of extra Redis  instance for locks\n- can do TTL on rows and columns\n\nDriverLock table (TTL)\n- Driver Id",
      "autoResize": false,
      "lineHeight": 1.25
    },
