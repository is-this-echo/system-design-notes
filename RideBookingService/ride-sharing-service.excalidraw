    {
      "id": "XJBv5OE45ufECGUDzXGJ7",
      "type": "text",
      "x": 2829.007126363382,
      "y": 447.2117880944923,
      "width": 484.28759765625,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1N",
      "roundness": null,
      "seed": 939755638,
      "version": 433,
      "versionNonce": 1458927338,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765607299458,
      "link": null,
      "locked": false,
      "text": "Ride table, status can be as below, when driver picks up\nrider then it makes a call to the /ride/driver/update endpoint\nand we send the destination address\nenum class RideStatus\n{\n    fare_estimated, matched, picked_up, dropped_off\n} ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ride table, status can be as below, when driver picks up\nrider then it makes a call to the /ride/driver/update endpoint\nand we send the destination address\nenum class RideStatus\n{\n    fare_estimated, matched, picked_up, dropped_off\n} ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kRspBzSKoM-iDrxzEGGfx",
      "type": "text",
      "x": 2116.393223580582,
      "y": 910.1891574198676,
      "width": 153.96788024902344,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1O",
      "roundness": null,
      "seed": 1628463734,
      "version": 74,
      "versionNonce": 400521130,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765634960731,
      "link": null,
      "locked": false,
      "text": "6M drivers\n3M active drivers\n3M / 5 =  600k qps",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "6M drivers\n3M active drivers\n3M / 5 =  600k qps",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "bYCgb_G8EPkp5yGXWWPJV",
      "type": "text",
      "x": 2580.93611715372,
      "y": 1069.683520744204,
      "width": 479.5355529785156,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1P",
      "roundness": null,
      "seed": 1649892266,
      "version": 481,
      "versionNonce": 1948296246,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765640152819,
      "link": null,
      "locked": false,
      "text": "Postgres - not ideal ?\n- Range query using 4 total bounds - left, right, up and down\n- lat, long - 2d index not good, B-trees optimized for 1 index\n- not optimized for larger regions as rows increases\n- db supports only 2k-3k qps",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Postgres - not ideal ?\n- Range query using 4 total bounds - left, right, up and down\n- lat, long - 2d index not good, B-trees optimized for 1 index\n- not optimized for larger regions as rows increases\n- db supports only 2k-3k qps",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Nare45xLIf1DS4XcIpZ7e",
      "type": "text",
      "x": 2580.692097197929,
      "y": 913.7167060518742,
      "width": 505.40753173828125,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Q",
      "roundness": null,
      "seed": 1407042666,
      "version": 495,
      "versionNonce": 1417796778,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765640154489,
      "link": null,
      "locked": false,
      "text": "Geo-spatial index for spatial queries\n- quadTree - PostGIS\n- good for uneven distribution of locations\n- not good for very high updates as it requires re-indexing\n- use a message queue to serve increasing requests\n- requires more space for storage, maintaining trees and pointers",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Geo-spatial index for spatial queries\n- quadTree - PostGIS\n- good for uneven distribution of locations\n- not good for very high updates as it requires re-indexing\n- use a message queue to serve increasing requests\n- requires more space for storage, maintaining trees and pointers",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "idJvxPVf3UT87rsDr-g3a",
      "type": "text",
      "x": 2579.4716994703085,
      "y": 712.8392326369991,
      "width": 412.09564208984375,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1R",
      "roundness": null,
      "seed": 103979830,
      "version": 284,
      "versionNonce": 395828022,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765699449306,
      "link": null,
      "locked": false,
      "text": "Redis cluster\n- 100k to 1M qps\n- geohashing\n- better when we have even distribution of locations\n- good for high frequency of writes\n- less storage overhead",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Redis cluster\n- 100k to 1M qps\n- geohashing\n- better when we have even distribution of locations\n- good for high frequency of writes\n- less storage overhead",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XO_UEaCB5uCujajFqO-o2",
      "type": "text",
      "x": 1974.5712222880425,
      "y": 1017.8672013268474,
      "width": 473.4681086006972,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1T",
      "roundness": null,
      "seed": 423194102,
      "version": 725,
      "versionNonce": 967008426,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765641621691,
      "link": null,
      "locked": false,
      "text": "600k qps is really high, how can it be made lower?\n- set periodic update time from 5sec to 15sec or even 1min\n- do dynamic filtering on the client\n    - based on status, accepting rides? if not then no need\nto update frequently\n    - based on speed, parked? location not changing for\nsometime, delay updates\n    - proximity to ride request/hot areas, outside of typical\nworking range, reduce frequency of updates\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "600k qps is really high, how can it be made lower?\n- set periodic update time from 5sec to 15sec or even 1min\n- do dynamic filtering on the client\n    - based on status, accepting rides? if not then no need to update frequently\n    - based on speed, parked? location not changing for sometime, delay updates\n    - proximity to ride request/hot areas, outside of typical working range, reduce frequency of updates\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "-FEc1skr2Dw4TckWjSwpZ",
      "type": "text",
      "x": 1428.7576356335212,
      "y": -165.56404341390962,
      "width": 512.3995361328125,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1V",
      "roundness": null,
      "seed": 1306800490,
      "version": 309,
      "versionNonce": 579801654,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "GNK6MgeHdyw2KtUK90uRe",
          "type": "arrow"
        },
        {
          "id": "xj-2Oj9lsHSMcTfLXoXkF",
          "type": "arrow"
        }
      ],
      "updated": 1765690886970,
      "link": null,
      "locked": false,
      "text": "Consistency of matching\n\n1. We don't send more than one request at a time for a given ride\n2. We don't send any driver more than one request at a time ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Consistency of matching\n\n1. We don't send more than one request at a time for a given ride\n2. We don't send any driver more than one request at a time ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Krs8uXXj89MXvqgu42tUy",
      "type": "text",
      "x": 1501.9814061817299,
      "y": -294.4379577902805,
      "width": 456.047607421875,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1W",
      "roundness": null,
      "seed": 1447511530,
      "version": 316,
      "versionNonce": 1701278966,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765687877765,
      "link": null,
      "locked": false,
      "text": "for 1, use like a while loop to send ride request to drivers,\nwait for 10secs and move on to the next driver,\nrepeat until ride is matched (i.e. driver accepts)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "for 1, use like a while loop to send ride request to drivers,\nwait for 10secs and move on to the next driver,\nrepeat until ride is matched (i.e. driver accepts)",
      "autoResize": true,
      "lineHeight": 1.25
    },
