    {
      "id": "Y9hOE0bgUMItE38WgL2B7",
      "type": "text",
      "x": 2092.231601317408,
      "y": -562.8712673197913,
      "width": 739.9354858398438,
      "height": 380,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1c",
      "roundness": null,
      "seed": 140672182,
      "version": 1577,
      "versionNonce": 370500522,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765697538224,
      "link": null,
      "locked": false,
      "text": "Let's say a LinkinPark concert ended in Bangalore,\nand the closest driver is same for a lot of riders.\n\nWhen each instance of Ride Matching Service pulls up\na list of drivers where Driver 1 is top choice, then it\nwill get 100's of alert at the same time - not good\n\n-  to solve this we can have another status in Driver DB - request_sent\n    when we send a ride notification to the driver, we persist the status in DB\n    before sending, other instance can check each driver's status on DB before\n    sending them a ride request notification, DB operations need to be atomic\n    \n  - Driver gets few secs (5s) to accept/deny on the popup, if he doesn't respond\n    then the status is stuck on request_sent, for that we can use a cron job service which\n    runs let's say every 1 min to update the status, for that we need another field\n    StatusUpdateTime, anyone having request_sent status for more than 10secs, make it\n    available.\n    Problem is the additional time delta introduced, if cron job runs after every 1 min and delta\n    is 5 secs, it could take up to 55 secs for the drive to get unlocked.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Let's say a LinkinPark concert ended in Bangalore,\nand the closest driver is same for a lot of riders.\n\nWhen each instance of Ride Matching Service pulls up\na list of drivers where Driver 1 is top choice, then it\nwill get 100's of alert at the same time - not good\n\n-  to solve this we can have another status in Driver DB - request_sent\n    when we send a ride notification to the driver, we persist the status in DB\n    before sending, other instance can check each driver's status on DB before\n    sending them a ride request notification, DB operations need to be atomic\n    \n  - Driver gets few secs (5s) to accept/deny on the popup, if he doesn't respond\n    then the status is stuck on request_sent, for that we can use a cron job service which\n    runs let's say every 1 min to update the status, for that we need another field\n    StatusUpdateTime, anyone having request_sent status for more than 10secs, make it\n    available.\n    Problem is the additional time delta introduced, if cron job runs after every 1 min and delta\n    is 5 secs, it could take up to 55 secs for the drive to get unlocked.",
      "autoResize": true,
      "lineHeight": 1.25
    },
