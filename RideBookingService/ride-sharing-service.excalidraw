    {
      "id": "XtqM02LFVHepWIFfSy09X",
      "type": "text",
      "x": 1499.706533595374,
      "y": -343.49396707842357,
      "width": 478.5435791015625,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
