      "seed": 1362653110,
      "version": 413,
      "versionNonce": 1417821354,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765699209844,
      "link": null,
      "locked": false,
      "text": "Not a FIFO queue but partitioned\nby regions because\nwe can have some harder to match\nrequests at the front (maybe coz of\nless drivers available to pickup in starting location)\nand easily matched rides are sitting at the back of the queue",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Not a FIFO queue but partitioned\nby regions because\nwe can have some harder to match\nrequests at the front (maybe coz of\nless drivers available to pickup in starting location)\nand easily matched rides are sitting at the back of the queue",
