  "elements": [
    {
      "id": "FA8yzdljwfzEubxozS9fN",
      "type": "text",
      "x": 305.1818050037731,
      "y": 157.22731919722122,
      "width": 803.5354614257812,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0Q",
      "roundness": null,
      "seed": 528331242,
      "version": 490,
      "versionNonce": 163560490,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765115210821,
      "link": null,
      "locked": false,
      "text": "Uber is a ride-sharing platform that connects passengers with drivers who offer transportation\nservices in personal vehicles. It allows users to book rides on-demand from their smartphones,\nmatching them with a nearby driver who will take them from their location to their desired destination.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Uber is a ride-sharing platform that connects passengers with drivers who offer transportation\nservices in personal vehicles. It allows users to book rides on-demand from their smartphones,\nmatching them with a nearby driver who will take them from their location to their desired destination.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "V2SpLw7l6QrVVC4-Hbpe7",
      "type": "text",
      "x": 301.3499272664387,
      "y": 108.95562489827478,
      "width": 460.5157775878906,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0R",
      "roundness": null,
      "seed": 223892790,
      "version": 31,
      "versionNonce": 571972714,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765115200620,
      "link": null,
      "locked": false,
      "text": "Design Uber (ride-sharing-service)",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design Uber (ride-sharing-service)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "X4QF800ivOCVC5y5PWz2y",
      "type": "text",
      "x": 308.6989402569411,
      "y": 287.622214533951,
      "width": 736.4473876953125,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0S",
      "roundness": null,
      "seed": 601022954,
      "version": 492,
      "versionNonce": 1659799338,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765119064051,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n\n1. Users should be able to input a start location and a destination and get an estimated fare\n2. Users should be able to request a ride based on the estimate\n3. Drivers should be able to accept/deny request and navigate to pickup/dropff\n\n---- out of scope ----\n- multiple car types\n- ratings for drivers and riders\n- schedule a ride in advance\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n\n1. Users should be able to input a start location and a destination and get an estimated fare\n2. Users should be able to request a ride based on the estimate\n3. Drivers should be able to accept/deny request and navigate to pickup/dropff\n\n---- out of scope ----\n- multiple car types\n- ratings for drivers and riders\n- schedule a ride in advance\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "H6bCqGIkqh-cpMgoLrt71",
      "type": "text",
      "x": 309.45460999593837,
      "y": 536.2508339821902,
      "width": 782.9913330078125,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0T",
      "roundness": null,
      "seed": 2086677174,
      "version": 743,
      "versionNonce": 465268214,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765474646698,
      "link": null,
      "locked": false,
      "text": "Non-functional Requirements\n\n1. low latency ride matching < 3 min to match or failure\n2. consistency of matching, ride : driver ratio = 1 : 1 (one ride should be matched to only one driver)\n3. highly available system outside the matching\n4. handle high throughput, surges for special events or peak hours\n    - 100k requests/sec in a region\n\n---- out of scope ----\n- GDPR user privacy\n- resilience and handling system failures\n- monitoring, logging or alert systems\n- CI/CD pipelines\n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional Requirements\n\n1. low latency ride matching < 3 min to match or failure\n2. consistency of matching, ride : driver ratio = 1 : 1 (one ride should be matched to only one driver)\n3. highly available system outside the matching\n4. handle high throughput, surges for special events or peak hours\n    - 100k requests/sec in a region\n\n---- out of scope ----\n- GDPR user privacy\n- resilience and handling system failures\n- monitoring, logging or alert systems\n- CI/CD pipelines\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "tYZfikDXKDmZGc1pScg82",
      "type": "text",
      "x": 310.4982442658262,
      "y": 853.443458153141,
      "width": 624.8953857421875,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
