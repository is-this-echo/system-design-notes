      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "71IokqAqipWV3QHeavrBj",
      "type": "text",
      "x": 309.6414618351822,
      "y": 955.3847346447433,
      "width": 459.03955078125,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0V",
      "roundness": null,
      "seed": 614990966,
      "version": 175,
      "versionNonce": 811152950,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765391407245,
      "link": null,
      "locked": false,
      "text": "Core Entities (DB tables/ data models or objects in code)\n\n- Ride\n- Driver\n- Rider\n- Location (for drivers)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core Entities (DB tables/ data models or objects in code)\n\n- Ride\n- Driver\n- Rider\n- Location (for drivers)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-ataHDcRdvuPmscQz6P3R",
      "type": "text",
      "x": 315.6380565289763,
      "y": 1135.2810232276795,
      "width": 876.9431762695312,
      "height": 620,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0W",
      "roundness": null,
      "seed": 395900534,
      "version": 1021,
      "versionNonce": 746092598,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1765394381737,
      "link": null,
      "locked": false,
      "text": "API (userId stuff is in the jwt/header of request and not in body for security, think impersonating other user)\n\n- POST /ride/fare-estimate -> Partial<Ride> (we are interested in a part of the Ride obj - rideId, ETA, price)\n  {\n        source,\n        destination\n  }\n\n- PATCH /ride/request -> 200 status (async api, used for ride booking)\n  {\n        rideId\n  }\n \n- POST /location/update (sends the driver's location to our servers every few seconds for ride matching algo)\n  {\n        lat,\n        long\n  }\n\n- PATCH /ride/driver/accept (when driver get's a notification for ride request)\n  {\n        rideId,\n        true/false (accept/deny)\n  }\n\n \n- PATCH /ride/driver/update -> lat/long | null : when picked_up provide them start location else null\n  {\n       rideId,\n        status : 'picked_up' | 'dropped_off'\n  }",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API (userId stuff is in the jwt/header of request and not in body for security, think impersonating other user)\n\n- POST /ride/fare-estimate -> Partial<Ride> (we are interested in a part of the Ride obj - rideId, ETA, price)\n  {\n        source,\n        destination\n  }\n\n- PATCH /ride/request -> 200 status (async api, used for ride booking)\n  {\n        rideId\n  }\n \n- POST /location/update (sends the driver's location to our servers every few seconds for ride matching algo)\n  {\n        lat,\n        long\n  }\n\n- PATCH /ride/driver/accept (when driver get's a notification for ride request)\n  {\n        rideId,\n        true/false (accept/deny)\n  }\n\n \n- PATCH /ride/driver/update -> lat/long | null : when picked_up provide them start location else null\n  {\n       rideId,\n        status : 'picked_up' | 'dropped_off'\n  }",
      "autoResize": true,
      "lineHeight": 1.25
    },
