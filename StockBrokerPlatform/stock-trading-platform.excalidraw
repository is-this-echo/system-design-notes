      "updated": 1756837314350,
      "link": null,
      "locked": false,
      "text": "Hybrid model for scaling\nthe pricing server for high ticking stocks\nis use of beefed up servers",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Hybrid model for scaling\nthe pricing server for high ticking stocks\nis use of beefed up servers",
      "autoResize": true,
      "lineHeight": 1.25
