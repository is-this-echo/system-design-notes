    {
      "id": "RlPBD-Nq29K5uljovSOi5",
      "type": "text",
      "x": 1933.8000183105466,
      "y": 483.46676635742176,
      "width": 288.751708984375,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0V",
      "roundness": null,
      "seed": 614652534,
      "version": 740,
      "versionNonce": 1362906166,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1756837095511,
      "link": null,
      "locked": false,
      "text": "From gateway processor \nto pricing server,\nwe stream instrument prices\nand each pricing service \ncan subscribe to the instruments\nit needs based on the clients\nit servers in that shard\n\nKafka can stream > 1M msg\nper sec, the problem is our pricing\nservice will have to pull the \ndata from the queue.\n\nWe need a push-based mechanism,\nRedis realtime -pub/sub uses \npush based mechanism which is \nfavorable for us. But tick orders are\nnot guaranteed here.\n\nKafka ensure ordering of messages.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "From gateway processor \nto pricing server,\nwe stream instrument prices\nand each pricing service \ncan subscribe to the instruments\nit needs based on the clients\nit servers in that shard\n\nKafka can stream > 1M msg\nper sec, the problem is our pricing\nservice will have to pull the \ndata from the queue.\n\nWe need a push-based mechanism,\nRedis realtime -pub/sub uses \npush based mechanism which is \nfavorable for us. But tick orders are\nnot guaranteed here.\n\nKafka ensure ordering of messages.",
      "autoResize": true,
      "lineHeight": 1.25
    },
