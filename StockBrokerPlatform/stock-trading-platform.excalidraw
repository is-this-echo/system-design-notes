  "elements": [
    {
      "id": "Khfix7IPU7ZUZRYKU4Zmo",
      "type": "text",
      "x": 251.19998168945312,
      "y": 124.00001525878906,
      "width": 492.07177734375,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
