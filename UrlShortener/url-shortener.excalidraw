    },
    {
      "id": "hfM2iulXauIrxzHaq9iik",
      "type": "text",
      "x": 1595.1779956372454,
      "y": 628.6784986481554,
      "width": 818.3988647460938,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3G",
      "roundness": null,
      "seed": 298949928,
      "version": 384,
      "versionNonce": 639280728,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1751303287565,
      "link": null,
      "locked": false,
      "text": "Since, now we have to make network\ncalls to Redis to get the counter,\nwe can store the next 1000 counts\nwhen a server comes online, obv global counter is incremented.\nIf the server goes down, we lose the counts but it's fine given the range of 56B urls we have\nbefore having to move on to the 7th char",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Since, now we have to make network\ncalls to Redis to get the counter,\nwe can store the next 1000 counts\nwhen a server comes online, obv global counter is incremented.\nIf the server goes down, we lose the counts but it's fine given the range of 56B urls we have\nbefore having to move on to the 7th char",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cNkpTlwDhK6bzGD3UMnJD",
      "type": "text",
      "x": 2310.1144076613646,
      "y": 441.3808138424219,
      "width": 334.3995361328125,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3I",
      "roundness": null,
      "seed": 1419953960,
      "version": 171,
      "versionNonce": 152189736,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1751304281679,
      "link": null,
      "locked": false,
      "text": "8 + 100 + 100 + 8 + 8 + 10 ~ 300 bytes\n300 bytes * 1B rows = 600GB ",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "8 + 100 + 100 + 8 + 8 + 10 ~ 300 bytes\n300 bytes * 1B rows = 600GB ",
      "autoResize": true,
      "lineHeight": 1.25
    },
