      "isDeleted": false,
      "boundElements": null,
      "updated": 1751303339866,
      "link": null,
      "locked": false,
      "text": "Redis\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Redis\n",
      "autoResize": true,
