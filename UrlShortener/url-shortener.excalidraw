    {
      "id": "iTTWPV6paNIRMJnaoy1Gb",
      "type": "text",
      "x": 2243.0982917158826,
      "y": 1206.1391128071489,
      "width": 501.59930419921875,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2F",
      "roundness": null,
      "seed": 1356277288,
      "version": 619,
      "versionNonce": 1826532952,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1751294594559,
      "link": null,
      "locked": false,
      "text": "Primary service in California\nCDNs distributed in important regions across the world\n\ncached responses from CDN are served to users,\nsince it doesn't go through our servers we might miss out\non logging, analytics of the requests made, so its \na trade-off b/w latency and data collection, we might\neven not know if our service is working or not\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Primary service in California\nCDNs distributed in important regions across the world\n\ncached responses from CDN are served to users,\nsince it doesn't go through our servers we might miss out\non logging, analytics of the requests made, so its \na trade-off b/w latency and data collection, we might\neven not know if our service is working or not\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aLJZz17zyc-uqdCdu6pQ3",
      "type": "text",
      "x": 1184.0985053389293,
      "y": 1363.138977385396,
      "width": 360.79949951171875,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2G",
      "roundness": null,
      "seed": 107816744,
      "version": 400,
      "versionNonce": 219306584,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1751300499476,
      "link": null,
      "locked": false,
      "text": "avg 1 req/user\n\n10^8 / 10^5 = 1000 qps evenly distributed\npeak load : 100,000 qps\n\nt3 medium ec2 instance ~ 1k qps\n- scale horizontally\n- read-heavy system\n    - 1qps write compared to 1k qps reads\n\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "avg 1 req/user\n\n10^8 / 10^5 = 1000 qps evenly distributed\npeak load : 100,000 qps\n\nt3 medium ec2 instance ~ 1k qps\n- scale horizontally\n- read-heavy system\n    - 1qps write compared to 1k qps reads\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
